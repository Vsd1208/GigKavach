PORT=4000
MONGODB_URI=
MONGODB_DB=gigshield
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Web Push (lock-screen / mobile browser notifications). Generate keys: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
# mailto: or https: URL (required by Web Push spec)
WEB_PUSH_SUBJECT=mailto:gigshield@example.com

# SMS (Twilio). Trial accounts can only SMS verified numbers.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
